# ============================================================
# Variables para el deploy con Docker Compose en Dokploy
# Copia estas variables en la pestaña "Environment" de Dokploy
# ============================================================

# --- Base de datos MySQL ---
MYSQL_ROOT_PASSWORD=cambia-esta-password-root
MYSQL_DATABASE=sistema_email
MYSQL_USER=sistema_email_user
MYSQL_PASSWORD=cambia-esta-password

# --- Backend ---
JWT_SECRET=cambia-este-secret-por-uno-seguro-y-aleatorio
# Dominio público del frontend (para CORS y redirects)
FRONTEND_URL=https://tu-dominio.com
# Orígenes permitidos por CORS (separados por coma)
ALLOWED_ORIGINS=https://tu-dominio.com

# --- URL pública del backend (se inyecta en el build del frontend) ---
# Sin /api al final. Ej: https://api.tu-dominio.com
NEXT_PUBLIC_API_URL=https://api.tu-dominio.com

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- PayPal ---
PAYPAL_CLIENT_ID=tu_client_id_de_paypal
PAYPAL_CLIENT_SECRET=tu_client_secret_de_paypal
PAYPAL_MODE=sandbox

# --- Email SMTP (opcional) ---
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_NAME=Fylo Mail

# --- Sincronización automática de correos ---
ENABLE_EMAIL_SYNC=false
EMAIL_SYNC_INTERVAL=5
