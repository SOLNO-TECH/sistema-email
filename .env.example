# ============================================================
# Variables para Dokploy (pestaña Environment)
# ============================================================

# OBLIGATORIO
JWT_SECRET=cambia-este-secret-por-uno-seguro-y-aleatorio-minimo-32-caracteres

# Tu dominio publico (el mismo en los 3)
FRONTEND_URL=https://mail.tudominio.com
ALLOWED_ORIGINS=https://mail.tudominio.com
NEXT_PUBLIC_API_URL=https://mail.tudominio.com

# Stripe (opcional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal (opcional)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Email SMTP (opcional)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_NAME=Fylo Mail

ENABLE_EMAIL_SYNC=false
EMAIL_SYNC_INTERVAL=5

# ============================================================
# DOKPLOY - DOMINIO (solo necesitas UNO)
# ============================================================
# Service Name: client
# Host: mail.tudominio.com
# Container Port: 3000
# Path: /
#
# NO necesitas dominio separado para el server.
# Next.js redirige /api/* al backend internamente.
